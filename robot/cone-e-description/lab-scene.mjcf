<mujoco model="lab_scene">
  <!--
    Lab scene matching real-world setup:
    - Black surface table with robot on top
    - 1 black wall (back), 2 white walls (sides)
    - Mini fridge on the table
    - Robot (dual Piper arms on welded base + lift)

    Place this file in your mjcf/ directory alongside robot-welded-base-and-lift.mjcf

    The robot base sits at z~0.1 (wheel radius above z=0).
    z=0 is treated as the table surface; real floor is below at z=-0.75.
  -->

  <include file="robot-welded-base-and-lift.mjcf"/>

  <statistic center="0.2 0 0.3" extent="1.0" meansize="0.05"/>

  <visual>
    <headlight diffuse="0.5 0.5 0.5" ambient="0.2 0.2 0.2" specular="0.15 0.15 0.15"/>
    <rgba haze="0.1 0.1 0.12 1"/>
    <global azimuth="150" elevation="-25"/>
    <quality shadowsize="4096"/>
  </visual>

  <asset>
    <!-- Skybox (dark room) -->
    <texture type="skybox" builtin="gradient" rgb1="0.08 0.08 0.1" rgb2="0.02 0.02 0.04"
             width="512" height="3072"/>

    <!-- Real floor (below table) -->
    <texture type="2d" name="real_floor_tex" builtin="flat" rgb1="0.25 0.25 0.25"
             width="512" height="512"/>
    <material name="real_floor_mat" texture="real_floor_tex" texuniform="true"
              reflectance="0.08" rgba="0.25 0.25 0.25 1"/>

    <!-- Black table surface -->
    <material name="black_surface_mat" rgba="0.04 0.04 0.04 1" reflectance="0.03"/>

    <!-- Table frame (dark metal) -->
    <material name="table_frame_mat" rgba="0.1 0.1 0.1 1" reflectance="0.15"/>

    <!-- Walls -->
    <material name="black_wall_mat" rgba="0.04 0.04 0.04 1" reflectance="0.01"/>
    <material name="white_wall_mat" rgba="0.93 0.93 0.91 1" reflectance="0.12"/>

    <!-- Fridge -->
    <material name="fridge_white_mat" rgba="0.94 0.94 0.94 1" reflectance="0.25"/>
    <material name="fridge_interior_mat" rgba="0.6 0.75 0.9 1" reflectance="0.05"/>
    <material name="fridge_handle_mat" rgba="0.65 0.65 0.65 1" reflectance="0.4"/>
  </asset>

  <worldbody>
    <!-- ===== Lighting ===== -->
    <light pos="0.2 0 1.6" dir="0 0 -1" directional="false"
           diffuse="0.65 0.63 0.6" specular="0.25 0.25 0.25"
           cutoff="65" attenuation="1 0.05 0.01"/>
    <light pos="-0.6 0.8 1.3" dir="0.4 -0.5 -0.6" directional="false"
           diffuse="0.25 0.25 0.28" specular="0.1 0.1 0.1"
           cutoff="70" attenuation="1 0.1 0.02"/>
    <light pos="0.9 -0.3 1.0" dir="-0.6 0.2 -0.4" directional="false"
           diffuse="0.15 0.15 0.18" specular="0.05 0.05 0.05" cutoff="80"/>

    <!-- ===== Real floor (below table) ===== -->
    <geom name="real_floor" type="plane" size="3 3 0.05"
          pos="0 0 -0.75" material="real_floor_mat"/>

    <!-- ===== Table ===== -->
    <body name="table" pos="0.25 0 0">
      <!-- Table top surface -->
      <geom name="table_top" type="box" size="0.60 0.375 0.012"
            pos="0 0 -0.012" material="black_surface_mat"
            contype="1" conaffinity="1" friction="1 0.01 0.01" mass="20"/>
      <!-- Black mat/cloth on surface -->
      <geom name="table_cloth" type="box" size="0.55 0.34 0.0005"
            pos="0 0 0.0005" material="black_surface_mat"
            contype="1" conaffinity="1" friction="1.5 0.01 0.01" mass="0.5"/>
      <!-- Legs -->
      <geom name="leg_fl" type="box" size="0.02 0.02 0.363"
            pos="-0.56 0.33 -0.387" material="table_frame_mat" mass="1.5"/>
      <geom name="leg_fr" type="box" size="0.02 0.02 0.363"
            pos="0.56 0.33 -0.387" material="table_frame_mat" mass="1.5"/>
      <geom name="leg_bl" type="box" size="0.02 0.02 0.363"
            pos="-0.56 -0.33 -0.387" material="table_frame_mat" mass="1.5"/>
      <geom name="leg_br" type="box" size="0.02 0.02 0.363"
            pos="0.56 -0.33 -0.387" material="table_frame_mat" mass="1.5"/>
      <!-- Cross braces -->
      <geom name="brace_f" type="box" size="0.54 0.015 0.015"
            pos="0 0.33 -0.55" material="table_frame_mat" mass="0.5"/>
      <geom name="brace_b" type="box" size="0.54 0.015 0.015"
            pos="0 -0.33 -0.55" material="table_frame_mat" mass="0.5"/>
    </body>

    <!-- ===== Walls ===== -->
    <!-- BACK wall (BLACK) -->
    <geom name="back_wall" type="box" size="1.8 0.005 1.1"
          pos="0.25 -0.55 0.35" material="black_wall_mat"
          contype="0" conaffinity="0" mass="0"/>
    <!-- LEFT wall (WHITE) -->
    <geom name="left_wall" type="box" size="0.005 0.55 1.1"
          pos="-0.6 0 0.35" material="white_wall_mat"
          contype="0" conaffinity="0" mass="0"/>
    <!-- RIGHT wall (WHITE) -->
    <geom name="right_wall" type="box" size="0.005 0.55 1.1"
          pos="1.1 0 0.35" material="white_wall_mat"
          contype="0" conaffinity="0" mass="0"/>

    <!-- ===== Mini Fridge ===== -->
    <!-- ~28W x 25D x 35H cm, on the table, right of robot -->
    <body name="fridge" pos="0.55 0.05 0.175">
      <!-- Shell panels -->
      <geom name="fridge_back" type="box" size="0.14 0.004 0.175"
            pos="0 -0.121 0" material="fridge_white_mat"
            contype="1" conaffinity="1" mass="1.5"/>
      <geom name="fridge_left" type="box" size="0.004 0.125 0.175"
            pos="-0.136 0 0" material="fridge_white_mat"
            contype="1" conaffinity="1" mass="0.8"/>
      <geom name="fridge_right" type="box" size="0.004 0.125 0.175"
            pos="0.136 0 0" material="fridge_white_mat"
            contype="1" conaffinity="1" mass="0.8"/>
      <geom name="fridge_top_panel" type="box" size="0.14 0.125 0.004"
            pos="0 0 0.171" material="fridge_white_mat"
            contype="1" conaffinity="1" mass="0.5"/>
      <geom name="fridge_bottom_panel" type="box" size="0.14 0.125 0.004"
            pos="0 0 -0.171" material="fridge_white_mat"
            contype="1" conaffinity="1" mass="0.5"/>

      <!-- Interior -->
      <geom name="fridge_int_back" type="box" size="0.13 0.002 0.165"
            pos="0 -0.113 0" material="fridge_interior_mat"
            contype="0" conaffinity="0" mass="0"/>
      <geom name="fridge_int_bottom" type="box" size="0.13 0.113 0.002"
            pos="0 0 -0.163" material="fridge_interior_mat"
            contype="1" conaffinity="1" mass="0"/>
      <geom name="fridge_shelf" type="box" size="0.12 0.10 0.002"
            pos="0 0.01 0.02" material="fridge_interior_mat"
            contype="1" conaffinity="1" mass="0.1"/>

      <!-- Door (open, hinged on right) -->
      <body name="fridge_door" pos="0.132 0.121 0">
        <joint name="fridge_door_hinge" type="hinge" axis="0 0 1"
               range="0 1.7" damping="0.5" stiffness="0.1"/>
        <geom name="fridge_door_panel" type="box" size="0.132 0.004 0.17"
              pos="-0.132 0.004 0" material="fridge_white_mat"
              contype="1" conaffinity="1" mass="0.6"/>
        <geom name="fridge_handle" type="capsule" size="0.006 0.04"
              pos="-0.24 0.018 0.05"
              material="fridge_handle_mat" mass="0.02"/>
      </body>

      <!-- Interior blue glow -->
      <light name="fridge_light" pos="0 0 0.12" dir="0 0.7 -0.3"
             diffuse="0.08 0.15 0.35" specular="0 0 0"
             cutoff="50" attenuation="1 4 10"/>
    </body>

    <!-- ===== Cameras ===== -->
    <camera name="lab_overview" pos="-0.5 1.8 1.0"
            xyaxes="0.95 0.3 0 -0.1 0.35 0.93" fovy="55" mode="fixed"/>
    <camera name="lab_photo_angle" pos="-0.3 0.9 0.9"
            xyaxes="0.96 0.28 0 -0.08 0.3 0.95" fovy="60" mode="fixed"/>
    <camera name="workspace_closeup" pos="0.2 0.7 0.6"
            xyaxes="1 0 0 0 0.4 0.9" fovy="50" mode="fixed"/>
    <camera name="topdown" pos="0.3 0 1.5"
            xyaxes="1 0 0 0 1 0" fovy="65" mode="fixed"/>
  </worldbody>

  <!-- Open the fridge door by default (matching photo) -->
  <keyframe>
    <key name="lab_home"
         qpos="0.0 1.58065 -0.578175 0.0 -0.912 0.78
               0.0 1.58065 -0.578175 0.0 -0.912 -0.78
               1.3"
         ctrl="0.0 1.58065 -0.578175 0.0 -0.912 0.78
               0.0 1.58065 -0.578175 0.0 -0.912 -0.78"/>
  </keyframe>
</mujoco>
