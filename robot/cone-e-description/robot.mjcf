<mujoco model="cone-e">
  <compiler angle="radian" />
  <option integrator="implicitfast" cone="elliptic" impratio="10" gravity="0 0 -9.81" timestep="0.001" />
  <default>
    <default class="robot">
      <default class="motor">
        <joint />
        <motor />
      </default>
      <default class="steering_joint">
        <position kp="10" kv="1" inheritrange="1" />
        <joint frictionloss="0.001" range="-3.14159 3.14159" />
      </default>
      <default class="drive_joint">
        <velocity kv="1" />
        <joint frictionloss="0.001" />
      </default>
      <default class="visual">
        <geom material="visualgeom" type="mesh" contype="0" conaffinity="0" group="2" density="0"/>
      </default>
      <default class="collision">
        <geom type="capsule" condim="3" contype="0" conaffinity="1" priority="1" group="1" solref="0.005 1"
          friction="1 0.01 0.01" />
        <equality solimp="0.99 0.999 1e-05" solref="0.005 1" />
      </default>
      <default class="wheel">
        <!-- 4 is friction that opposes rotation around the contact normal -->
        <geom type="mesh" condim="4" contype="0" conaffinity="1" priority="1" group="1" solref="0.005 1"
          friction="1.2 0.005 0.005" />
      </default>
    </default>


    <default class="piper">
      <joint frictionloss="0.3" armature="0.005" />
      <position inheritrange="1" forcerange="-100 100" />
      <default class="collision_gripper">
        <geom type="mesh" group="3" friction="2 0.005 0.0001" density="100" />
      </default>
    </default>
  </default>


  <asset>
    <!-- base and lift assets -->
    <material name="base_material" rgba="1 0 0 1" />
    <material name="base_profile_short_material" rgba="0.701961 0.701961 0.701961 1" />
    <material name="Part_2_material" rgba="0.615686 0.811765 0.929412 1" />
    <material name="MK4_Colson_Hub_4_X_1.5_material" rgba="0.666667 0.698039 0.768627 1" />
    <material name="Lift_Middle_material" rgba="0.901961 0.901961 0.901961 1" />
    <material name="default_material" rgba="0.7 0.7 0.7 1" />

    <mesh name="base_profile_short.stl" file="meshes/base_profile_short.stl" />
    <mesh name="Part_2.stl" file="meshes/Part_2.stl" />
    <mesh name="MK4_Colson_Hub_4_X_1.5.stl" file="meshes/MK4_Colson_Hub_4_X_1.5.stl" />
    <mesh name="Part_2_2.stl" file="meshes/Part_2_2.stl" />
    <mesh name="MK4_Colson_Hub_4_X_1.5_2.stl" file="meshes/MK4_Colson_Hub_4_X_1.5_2.stl" />
    <mesh name="Part_2_3.stl" file="meshes/Part_2_3.stl" />
    <mesh name="MK4_Colson_Hub_4_X_1.5_3.stl" file="meshes/MK4_Colson_Hub_4_X_1.5_3.stl" />
    <mesh name="Part_2_4.stl" file="meshes/Part_2_4.stl" />
    <mesh name="MK4_Colson_Hub_4_X_1.5_4.stl" file="meshes/MK4_Colson_Hub_4_X_1.5_4.stl" />
    <mesh name="Lift_Middle.stl" file="meshes/Lift_Middle.stl" />
    <mesh name="Lift_Top.stl" file="meshes/Lift_Top.stl" />

    <!-- piper assets -->
    <material name="white" rgba="1 1 1 1" />
    <material name="gray" rgba="0.15 0.15 0.15 1" />
    <material name="light_gray" rgba="0.6 0.6 0.6 1" />
    <material name="light_blue" rgba="0.345 0.65 0.976 1" />
    <material name="black" rgba="0.05 0.05 0.05 1" />
    <material name="gray_mat" rgba="0.59 0.59 0.59 1" />
    <material name="dark_gray_mat" rgba="0.086 0.086 0.086 1" />
    <material name="light_medium_gray_mat" rgba="0.85 0.85 0.85 1" />

    <mesh name="link0" file="meshes/piper/link0.stl" />
