  <actuator>
    <position name="front_left_steer_ctrl" joint="front_left_steer" class="steering_joint" />
    <velocity name="drive_front_left_ctrl" joint="drive_front_left" class="drive_joint" />
    <position name="back_left_steer_ctrl" joint="back_left_steer" class="steering_joint" />
    <velocity name="drive_back_left_ctrl" joint="drive_back_left" class="drive_joint" />
    <position name="front_right_steer_ctrl" joint="front_right_steer" class="steering_joint" />
    <velocity name="drive_front_right_ctrl" joint="drive_front_right" class="drive_joint" />
    <position name="back_right_steer_ctrl" joint="back_right_steer" class="steering_joint" />
    <velocity name="drive_back_right_ctrl" joint="drive_back_right" class="drive_joint" />
    <motor name="Slider_1_ctrl" joint="Slider_1" class="motor" />
    <motor name="Slider_2_ctrl" joint="Slider_2" class="motor" />

    <!-- Piper actuators -->
     <!-- Left arm -->
    <position name="left_arm_joint1_pos" joint="left_arm_joint1" class="piper" kp="10" kv="1" />
    <position name="left_arm_joint2_pos" joint="left_arm_joint2" class="piper" kp="10" kv="1" />
    <position name="left_arm_joint3_pos" joint="left_arm_joint3" class="piper" kp="10" kv="1" />
    <position name="left_arm_joint4_pos" joint="left_arm_joint4" class="piper" kp="5" kv="1" />
    <position name="left_arm_joint5_pos" joint="left_arm_joint5" class="piper" kp="5" kv="1" />
    <position name="left_arm_joint6_pos" joint="left_arm_joint6" class="piper" kp="5" kv="1" />
     <!-- Right arm -->
    <position name="right_arm_joint1_pos" joint="right_arm_joint1" class="piper" kp="10" kv="1" />
    <!-- <velocity name="joint1_vel" joint="joint1" kv="5" />
    <motor name="joint1_torque" joint="joint1" /> -->
    <position name="right_arm_joint2_pos" joint="right_arm_joint2" class="piper" kp="10" kv="1" />
    <!-- <velocity name="joint2_vel" joint="joint2" kv="5" />
    <motor name="joint2_torque" joint="joint2" /> -->
    <position name="right_arm_joint3_pos" joint="right_arm_joint3" class="piper" kp="10" kv="1" />
    <!-- <velocity name="joint3_vel" joint="joint3" kv="5" />
    <motor name="joint3_torque" joint="joint3" /> -->
    <position name="right_arm_joint4_pos" joint="right_arm_joint4" class="piper" kp="5" kv="1" />
    <!-- <velocity name="joint4_vel" joint="joint4" kv="5" />
    <motor name="joint4_torque" joint="joint4" /> -->
    <position name="right_arm_joint5_pos" joint="right_arm_joint5" class="piper" kp="5" kv="1" />
    <!-- <velocity name="joint5_vel" joint="joint5" kv="1.5" />
    <motor name="joint5_torque" joint="joint5" /> -->
    <position name="right_arm_joint6_pos" joint="right_arm_joint6" class="piper" kp="5" kv="1" />
    <!-- <velocity name="joint6_vel" joint="joint6" kv="1.5" />
    <motor name="joint6_torque" joint="joint6" /> -->
  </actuator>

  <contact>
    <exclude body1="left_arm_link0" body2="left_arm_link1" />
    <exclude body1="right_arm_link0" body2="right_arm_link1" />
    <exclude body1="Lift_Top" body2="left_arm_link0" />
    <exclude body1="Lift_Top" body2="right_arm_link0" />
    <exclude body1="base_profile_short" body2="Part_2" />
    <exclude body1="base_profile_short" body2="Part_2_2" />
    <exclude body1="Part_2" body2="MK4_Colson_Hub_4_X_1.5" />
    <exclude body1="base_profile_short" body2="Part_2_3" />
    <exclude body1="Part_2_2" body2="MK4_Colson_Hub_4_X_1.5_2" />
    <exclude body1="base_profile_short" body2="Part_2_4" />
    <exclude body1="base_profile_short" body2="Lift_Middle" />
    <exclude body1="Part_2_3" body2="MK4_Colson_Hub_4_X_1.5_3" />
    <exclude body1="Part_2_4" body2="MK4_Colson_Hub_4_X_1.5_4" />
    <exclude body1="Lift_Middle" body2="Lift_Top" />
  </contact>

  <sensor>
    <framepos name="base_site_pos" objtype="site" objname="base_site" />
    <framequat name="base_site_quat" objtype="site" objname="base_site" />
    <framelinvel name="base_site_linvel" objtype="site" objname="base_site" />
    <frameangvel name="base_site_angvel" objtype="site" objname="base_site" />
