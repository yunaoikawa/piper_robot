<mujoco>
	<option gravity="0 0 -9.81" />
	<worldbody>
        <light cutoff="100" diffuse="1 1 1" dir="-0 0 -1.3" directional="true" exponent="1" pos="0 0 1.3" specular=".1 .1 .1"/>
        <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1"/>
		<geom type="plane" size="50 50 0.1" rgba=".9 .9 .9 1" material="checker_material"/>
		<body name="chassis" pos="0 0 0.6" euler='0 90 0'>
			<joint type="free"/>
			<geom type="box" size=".05 .9 .9" rgba=".1 .1 0 0.5" density="2000"/>
            <camera euler="180 -30 90" fovy="75" name="tracking_camera" pos="-2.5 0 -3" mode="trackcom"/>
			<site name="marker" pos = "0 0 0.6" size="0.1" />
			<body name="l-front-caster" pos="0.15 0.6 0.6" euler='135 90 0'>
                <joint damping="0.1" name="l-front-steer" type="hinge" axis="0 0 -1"/>
                <geom type="cylinder" size=".05 0.25" rgba="0 0 0 1"/>
                <body name="l-front-wheel" pos="0 0 0.2" euler="90 0 0">
                    <joint damping="0.1" name="l-front-wheel" type="hinge" axis="0 0 1" limited="false"/>
                    <geom type="cylinder" size=".2 0.02" rgba="0 1 0 0.8"/>
                </body>
                <body name="l-front-caster-axle" pos="0.1 0 0.2" euler="0 90 0">
                    <geom type="cylinder" size=".05 0.1" rgba="0 0 0 1"/>
                </body>
            </body>
            <body name="r-front-caster" pos="0.15 -0.6 0.6" euler='-135 90 0'>
                <joint damping="0.1" name="r-front-steer" type="hinge" axis="0 0 -1"/>
                <geom type="cylinder" size=".05 0.25" rgba="0 0 0 1"/>
                <body name="r-front-wheel" pos="0.0 0 0.2" euler="90 0 0">
                    <joint damping="0.1" name="r-front-wheel" type="hinge" axis="0 0 1" limited="false"/>
                    <geom type="cylinder" size=".2 0.02" rgba="0 1 0 0.8"/>
                </body>
                <body name="r-front-caster-axle" pos="0.1 0 0.2" euler="0 90 0">
                    <geom type="cylinder" size=".05 0.1" rgba="0 0 0 1"/>
                </body>
            </body>
            <body name="l-back-caster" pos="0.15 0.6 -0.6" euler='45 90 0'>
                <joint damping="0.1" name="l-back-steer" type="hinge" axis="0 0 -1"/>
                <geom type="cylinder" size=".05 0.25" rgba="0 0 0 1"/>
                <body name="l-back-wheel" pos="0 0 0.2" euler="90 0 0">
                    <joint damping="0.1" name="l-back-wheel" type="hinge" axis="0 0 1" limited="false"/>
                    <geom type="cylinder" size=".2 0.02" rgba="0 1 0 0.8"/>
                </body>
                <body name="l-back-caster-axle" pos="0.1 0 0.2" euler="0 90 0">
                    <geom type="cylinder" size=".05 0.1" rgba="0 0 0 1"/>
                </body>
            </body>
            <body name="r-back-caster" pos="0.15 -0.6 -0.6" euler='-45 90 0'>
                <joint damping="0.1" name="r-back-steer" type="hinge" axis="0 0 -1"/>
                <geom type="cylinder" size=".05 0.25" rgba="0 0 0 1"/>
                <body name="r-back-wheel" pos="0 0 0.2" euler="90 0 0">
                    <joint damping="0.1" name="r-back-wheel" type="hinge" axis="0 0 1" limited="false"/>
                    <geom type="cylinder" size=".2 0.02" rgba="0 1 0 0.8"/>
                </body>
                <body name="r-back-caster-axle" pos="0.1 0 0.2" euler="0 90 0">
                    <geom type="cylinder" size=".05 0.1" rgba="0 0 0 1"/>
                </body>
            </body>
		</body>
	</worldbody>
	<actuator>
        <velocity name="l-front-steer-servo" joint="l-front-steer" kv="10"/>
        <velocity name="r-front-steer-servo" joint="r-front-steer" kv="10"/>
		<velocity name="l-back-steer-servo" joint="l-back-steer" kv="10"/>
        <velocity name="r-back-steer-servo" joint="r-back-steer" kv="10"/>

        <velocity name="l-front-wheel-servo" joint="l-front-wheel" kv="10"/>
        <velocity name="r-front-wheel-servo" joint="r-front-wheel" kv="10"/>
        <velocity name="l-back-wheel-servo" joint="l-back-wheel" kv="10"/>
        <velocity name="r-back-wheel-servo" joint="r-back-wheel" kv="10"/>
	</actuator>
    <asset>
        <texture builtin="gradient" height="100" rgb1="1 1 1" rgb2="0 0 0" type="skybox" width="100"/>
        <texture builtin="flat" height="1278" mark="cross" markrgb="1 1 1" name="texgeom" random="0.01" rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" type="cube" width="127"/>
        <texture builtin="checker" height="100" name="texplane" rgb1="0 0 0" rgb2="0.8 0.8 0.8" type="2d" width="100"/>
        <material name="checker_material" reflectance="0.5" shininess="1" specular="1" texrepeat="60 60" texture="texplane"/>
        <material name="geom" texture="texgeom" texuniform="true"/>
    </asset>
    <sensor>
        <jointvel name="l-front-steer-vel" joint="l-front-steer"/>
        <jointvel name="r-front-steer-vel" joint="r-front-steer"/>
        <jointvel name="l-back-steer-vel" joint="l-back-steer"/>
        <jointvel name="r-back-steer-vel" joint="r-back-steer"/>

        <jointvel name="l-front-wheel-vel" joint="l-front-wheel"/>
        <jointvel name="r-front-wheel-vel" joint="r-front-wheel"/>
        <jointvel name="l-back-wheel-vel" joint="l-back-wheel"/>
        <jointvel name="r-back-wheel-vel" joint="r-back-wheel"/>

        <jointpos name="l-front-steer-pos" joint="l-front-steer"/>
        <jointpos name="r-front-steer-pos" joint="r-front-steer"/>
        <jointpos name="l-back-steer-pos" joint="l-back-steer"/>
        <jointpos name="r-back-steer-pos" joint="r-back-steer"/>

        <jointpos name="l-front-wheel-pos" joint="l-front-wheel"/>
        <jointpos name="r-front-wheel-pos" joint="r-front-wheel"/>
        <jointpos name="l-back-wheel-pos" joint="l-back-wheel"/>
        <jointpos name="r-back-wheel-pos" joint="r-back-wheel"/>
    </sensor>
</mujoco>