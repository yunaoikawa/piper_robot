<mujoco model="robot">
    <asset>
        <material name="aluminum" shininess="0.8" specular="0.8" reflectance="0.8" rgba="0.7 0.7 0.7 1"/>
    </asset>
    <worldbody>
        <body name="chassis" pos="0 0 0.3" euler="0 0 0">
            <joint type="free"/>
            <geom type="box" size="0.5 0.7 0.1" material="aluminum" rgba="0.7 0.7 0.7 1" density="5000"/>
            <!-- Front Left Wheel Assembly -->
            <body name="fl-module" pos="0.35 0.5 -0.1" euler="0 0 0">
                <joint name="fl-steer" type="hinge" axis="0 0 1" damping="0.2"/>
                <geom type="cylinder" size="0.05 0.1" rgba="0 0 0 1" density="3000"/>
                <body name="fl-wheel" pos="0 0 -0.1" euler="90 0 0">
                    <joint name="fl-wheel-joint" type="hinge" axis="0 0 -1" damping="0.2" limited="false"/>
                    <geom type="cylinder" size="0.15 0.05" rgba="0.8 0.8 0.8 0.8" density="3000"/>
                </body>
            </body>
            <!-- Front Right Wheel Assembly -->
            <body name="fr-module" pos="0.35 -0.5 -0.1" euler="0 0 0">
                <joint name="fr-steer" type="hinge" axis="0 0 1" damping="0.2"/>
                <geom type="cylinder" size="0.05 0.1" rgba="0 0 0 1" density="3000"/>
                <body name="fr-wheel" pos="0 0 -0.1" euler="90 0 0">
                    <joint name="fr-wheel-joint" type="hinge" axis="0 0 -1" damping="0.2" limited="false"/>
                    <geom type="cylinder" size="0.15 0.05" rgba="0.8 0.8 0.8 0.8" density="3000"/>
                </body>
            </body>
            <!-- Rear Left Wheel Assembly -->
            <body name="rl-module" pos="-0.35 0.5 -0.1" euler="0 0 0">
                <joint name="rl-steer" type="hinge" axis="0 0 1" damping="0.2"/>
                <geom type="cylinder" size="0.05 0.1" rgba="0 0 0 1" density="3000"/>
                <body name="rl-wheel" pos="0 0 -0.1" euler="90 0 0">
                    <joint name="rl-wheel-joint" type="hinge" axis="0 0 -1" damping="0.2" limited="false"/>
                    <geom type="cylinder" size="0.15 0.05" rgba="0.8 0.8 0.8 0.8" density="3000"/>
                </body>
            </body>
            <!-- Rear Right Wheel Assembly -->
            <body name="rr-module" pos="-0.35 -0.5 -0.1" euler="0 0 0">
                <joint name="rr-steer" type="hinge" axis="0 0 1" damping="0.2"/>
                <geom type="cylinder" size="0.05 0.1" rgba="0 0 0 1" density="3000"/>
                <body name="rr-wheel" pos="0 0 -0.1" euler="90 0 0">
                    <joint name="rr-wheel-joint" type="hinge" axis="0 0 -1" damping="0.2" limited="false"/>
                    <geom type="cylinder" size="0.15 0.05" rgba="0.8 0.8 0.8 0.8" density="3000"/>
                </body>
            </body>
        </body>
    </worldbody>
    <actuator>
        <position name="fl-steer-servo" joint="fl-steer" ctrlrange="-3.14 3.14" kp="3000"/>
        <position name="fr-steer-servo" joint="fr-steer" ctrlrange="-3.14 3.14" kp="3000"/>
        <position name="rl-steer-servo" joint="rl-steer" ctrlrange="-3.14 3.14" kp="3000"/>
        <position name="rr-steer-servo" joint="rr-steer" ctrlrange="-3.14 3.14" kp="3000"/>

        <velocity name="fl-wheel-servo" joint="fl-wheel-joint" kv="1200"/>
        <velocity name="fr-wheel-servo" joint="fr-wheel-joint" kv="1200"/>
        <velocity name="rl-wheel-servo" joint="rl-wheel-joint" kv="1200"/>
        <velocity name="rr-wheel-servo" joint="rr-wheel-joint" kv="1000"/>
    </actuator>
    <sensor>
        <jointvel name="fl-wheel-vel" joint="fl-wheel-joint"/>
        <jointvel name="fr-wheel-vel" joint="fr-wheel-joint"/>
        <jointvel name="rl-wheel-vel" joint="rl-wheel-joint"/>
        <jointvel name="rr-wheel-vel" joint="rr-wheel-joint"/>

        <jointpos name="fl-steer-pos" joint="fl-steer"/>
        <jointpos name="fr-steer-pos" joint="fr-steer"/>
        <jointpos name="rl-steer-pos" joint="rl-steer"/>
        <jointpos name="rr-steer-pos" joint="rr-steer"/>
    </sensor>
</mujoco>